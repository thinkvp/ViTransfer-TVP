model SecuritySettings {
  id String @id @default("default")

  // Hotlink Protection: DISABLED, LOG_ONLY, BLOCK_STRICT
  hotlinkProtection String @default("LOG_ONLY")

  // Rate Limiting (global only - per minute)
  ipRateLimit           Int  @default(1000) // requests per minute per IP (video streaming requires high limit)
  sessionRateLimit      Int  @default(600) // requests per minute per admin session (10/sec for seeking/buffering)
  shareSessionRateLimit Int  @default(300) // requests per minute per share session (client access)
  passwordAttempts      Int  @default(5) // password attempts before lockout
  shareTokenTtlSeconds  Int? // optional override for share JWT expiry (60-86400 seconds, null = use session timeout)

  // Session Timeout (for client share sessions, not admin JWT)
  sessionTimeoutValue Int    @default(15) // Numeric value (15, 30, 1, 2, etc.)
  sessionTimeoutUnit  String @default("MINUTES") // MINUTES, HOURS, DAYS, WEEKS

  // HTTPS Enforcement (HTTPS_ENABLED env var always takes precedence if set)
  httpsEnabled Boolean @default(true) // Enable HSTS (default: true for production security)

  // Logging toggles
  trackAnalytics    Boolean @default(true)
  trackSecurityLogs Boolean @default(true)

  // Security Dashboard Access
  viewSecurityEvents Boolean @default(false) // Show /admin/security page in navigation

  // Application safeguard limits
  maxInternalCommentsPerProject Int @default(250)
  maxCommentsPerVideoVersion    Int @default(100)
  maxProjectRecipients          Int @default(30)
  maxProjectFilesPerProject     Int @default(50)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SecurityEvent {
  id       String @id @default(cuid())
  type     String // HOTLINK_DETECTED, HOTLINK_BLOCKED, RATE_LIMIT_HIT, TOKEN_SESSION_MISMATCH, SUSPICIOUS_ACTIVITY, BLOCKED_IP_ATTEMPT
  severity String @default("INFO") // INFO, WARNING, CRITICAL

  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)

  videoId   String?
  sessionId String?
  ipAddress String?
  referer   String?

  // Additional context as JSON
  details Json?

  // Was this event auto-blocked?
  wasBlocked Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([type, createdAt])
  @@index([severity])
}

model BlockedIP {
  id        String   @id @default(cuid())
  ipAddress String   @unique
  reason    String?
  createdAt DateTime @default(now())
  createdBy String? // Admin user ID who blocked this IP

  @@index([ipAddress])
}

model BlockedDomain {
  id        String   @id @default(cuid())
  domain    String   @unique
  reason    String?
  createdAt DateTime @default(now())
  createdBy String? // Admin user ID who blocked this domain

  @@index([domain])
}

model VideoAnalytics {
  id String @id @default(cuid())

  videoId String
  video   Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Event types: PAGE_VISIT, DOWNLOAD_COMPLETE (legacy), DOWNLOAD_SUCCEEDED, DOWNLOAD_FAILED
  eventType String

  // Optional: Single asset ID for individual asset downloads
  assetId String?

  // Optional: Multiple asset IDs for ZIP downloads (JSON array)
  assetIds String?

  // Viewer IP (best-effort; may be null for older records)
  ipAddress String?

  // Share session ID for mapping to a recipient (best-effort)
  sessionId String?

  // Authentication metadata captured at the time of the event
  accessMethod String?
  email        String?

  // Additional context for richer analytics entries (speed, failure reason, etc.)
  details Json?

  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([videoId, createdAt])
  @@index([eventType])
  @@index([assetId])
  @@index([ipAddress])
  @@index([sessionId])
}

model AlbumAnalytics {
  id String @id @default(cuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  albumId String
  album   Album @relation(fields: [albumId], references: [id], onDelete: Cascade)

  photoId String?
  photo   AlbumPhoto? @relation(fields: [photoId], references: [id], onDelete: SetNull)

  // Event types: ALBUM_DOWNLOAD, PHOTO_DOWNLOAD
  eventType String

  // Optional: full or social variants for album/photo downloads
  variant String?

  // Additional context for download events (e.g. { source: 'S3' })
  details Json?

  ipAddress String?
  sessionId String?
  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([albumId, createdAt])
  @@index([photoId])
  @@index([eventType])
  @@index([sessionId])
}

model ProjectEmailEvent {
  id String @id @default(cuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Email notification type: ALL_READY_VIDEOS or SPECIFIC_VIDEO_VERSION
  type String

  // Optional idempotency key to dedupe log entries (allows multiple NULLs)
  dedupeKey String? @unique

  // Optional link to a specific video/version when applicable
  videoId String?
  video   Video?  @relation(fields: [videoId], references: [id], onDelete: SetNull)

  // JSON array of recipient email addresses
  recipientEmails String

  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([videoId])
  @@index([type])
}

model EmailTracking {
  id    String @id @default(cuid())
  token String @unique // Unique tracking token for this email/recipient

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Email type: ALL_READY_VIDEOS or SPECIFIC_VIDEO_VERSION
  type String

  // Optional link to specific video when applicable
  videoId String?
  video   Video?  @relation(fields: [videoId], references: [id], onDelete: SetNull)

  // Recipient email address
  recipientEmail String

  // Tracking timestamps
  sentAt   DateTime  @default(now())
  openedAt DateTime? // NULL if not opened yet

  @@index([projectId, openedAt])
  @@index([token])
  @@index([recipientEmail])
}

model SharePageAccess {
  id String @id @default(cuid())

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Authentication method used: OTP, PASSWORD, GUEST
  accessMethod String

  // ACCESS = page opened, SWITCH_AWAY = viewer switched from this project to another client project
  eventType String @default("ACCESS")

  // Email address (only for OTP authentication)
  email String?

  // Optional origin project title when arriving via project switching
  originProjectTitle String?

  // Optional target project title when leaving this project via project switching
  targetProjectTitle String?

  // JWT session ID for unique session tracking
  sessionId String

  // Client metadata
  ipAddress String?
  userAgent String?

  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([projectId, accessMethod])
  @@index([projectId, eventType])
  @@index([sessionId])
}

model GuestVideoShareLink {
  id String @id @default(cuid())

  // Random, non-guessable token used in the public URL.
  token String @unique

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // A Video row represents a specific version.
  videoId String
  video   Video @relation(fields: [videoId], references: [id], onDelete: Cascade)

  // Link expiry (14 days from generation).
  expiresAt DateTime

  createdAt DateTime @default(now())

  @@unique([projectId, videoId])
  @@index([expiresAt])
  @@index([projectId])
  @@index([videoId])
}

model PasskeyCredential {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // WebAuthn credential data (following SimpleWebAuthn patterns)
  credentialID Bytes  @unique // Authenticator's credential ID
  publicKey    Bytes // Public key for signature verification
  counter      BigInt // Signature counter (prevents replay attacks)

  // UX and security metadata
  transports     String[] // ['internal', 'usb', 'nfc', 'ble', 'hybrid']
  deviceType     String // 'singleDevice' | 'multiDevice' (cloud-synced passkey)
  backedUp       Boolean  @default(false) // Indicates key material is backed up
  aaguid         String? // Authenticator Attestation GUID (optional)
  userAgent      String? // Browser/device info for admin reference
  credentialName String? // User-friendly name: "MacBook Touch ID", "iPhone Passkey"

  // Security tracking
  createdAt  DateTime @default(now())
  lastUsedAt DateTime @default(now())
  lastUsedIP String?

  @@index([userId])
  @@index([userId, lastUsedAt])
}

model CommentFile {
  id          String   @id @default(cuid())
  commentId   String
  projectId   String
  fileName    String // Original filename (e.g., "design.pdf")
  fileType    String // MIME type (e.g., "application/pdf")
  createdAt   DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([commentId])
  @@index([projectId])
  @@index([projectId, createdAt])
}

// ===== StoredFile Registry =====
// Normalized table acting as the single source of truth for every file the system
// knows about.  Instead of scattering path columns (preview480Path, thumbnailPath,
// timelinePreviewVttPath, etc.) across a dozen entity tables, every file — original
// uploads, derived previews, thumbnails, ZIPs, branding assets — gets one row here.
//
// This makes scans, renames, storage totals, closed-project cleanup, and migration
// all operate on a single table instead of enumerating columns across every model.

enum EntityType {
  VIDEO
  VIDEO_ASSET
  SHARE_UPLOAD_FILE
  ALBUM_PHOTO
  ALBUM
  PROJECT_FILE
  CLIENT_FILE
  USER_FILE
  USER_AVATAR
  PROJECT_EMAIL
  PROJECT_EMAIL_ATTACHMENT
  COMMENT_FILE
  ACCOUNTING_ATTACHMENT
  SETTINGS_BRANDING
}

enum FileRole {
  ORIGINAL
  PREVIEW_480
  PREVIEW_720
  PREVIEW_1080
  THUMBNAIL
  PREVIEW_IMAGE
  PREVIEW_MP4
  SOCIAL
  TIMELINE_VTT
  TIMELINE_SPRITES
  HLS_PLAYLIST
  HLS_SEGMENTS
  AVATAR
  COMPANY_LOGO
  COMPANY_DARK_LOGO
  COMPANY_FAVICON
  RAW_EMAIL
  ZIP_FULL
  ZIP_SOCIAL
}

model StoredFile {
  id          String     @id @default(cuid())
  entityType  EntityType
  entityId    String     // owning record ID (Video.id, AlbumPhoto.id, etc.)
  fileRole    FileRole

  // Denormalized owning project, when the entity is project-scoped. Lets project-wide
  // lifecycle ops (delete, storage totals) run as one query instead of enumerating every
  // entity type. NULL for non-project files (user/client/branding/accounting). Auto-populated
  // by registerStoredFile() via resolveEntityProjectId(); stays correct because entity→project
  // is immutable for these types.
  projectId   String?

  storagePath String
  fileName    String?    // cached display name
  fileSize    BigInt?    // null = unknown (batchResolveFileSizes lazily backfills from S3 HEAD)
  status      String?    // PENDING | READY | ERROR (null for simple files)
  generatedAt DateTime?
  metadata    Json?      // { width, height, duration, codec, ... }

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([entityType, entityId, fileRole])
  @@index([entityType, entityId])
  @@index([storagePath])
  @@index([projectId])
}

model UserProjectViewSettings {
  id       String  @id @default(cuid())
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  // JSON object with section visibility settings
  // When projectId is null, this is the default for all projects
  // When projectId is set, this is the setting for a specific project
  visibleSections Json @default("{\"sales\":true,\"keyDates\":true,\"externalCommunication\":true,\"users\":true,\"projectFiles\":true,\"projectData\":true}")
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, projectId])
  @@index([userId])
  @@index([projectId])
}

/// Global library of reusable line items (independent of any preset)
model SalesItem {
  id             String            @id @default(cuid())
  description    String            @db.VarChar(500)
  details        String            @default("") @db.Text
  quantity       Float
  unitPriceCents Int
  taxRatePercent Float
  taxRateName    String?           @db.VarChar(200)
  labelId        String?
  label          SalesLabel?       @relation(fields: [labelId], references: [id], onDelete: SetNull)
  sortOrder      Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  presets        SalesPresetItem[]

  @@index([sortOrder])
  @@index([createdAt])
  @@index([labelId])
}

/// Named preset — stores which SalesItems should be auto-checked
model SalesPreset {
  id        String            @id @default(cuid())
  name      String            @unique @db.VarChar(200)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  items SalesPresetItem[]

  @@index([name])
}

/// Join table: which SalesItems belong to a SalesPreset
model SalesPresetItem {
  id        String      @id @default(cuid())
  presetId  String
  itemId    String
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())

  preset SalesPreset @relation(fields: [presetId], references: [id], onDelete: Cascade)
  item   SalesItem   @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([presetId, itemId])
  @@index([presetId])
  @@index([itemId])
}

/// Named labels for categorising line items — optionally mapped to a Chart of Accounts INCOME account
model SalesLabel {
  id          String   @id @default(cuid())
  name        String   @unique @db.VarChar(200)
  color       String?  @db.VarChar(7)   // Hex color e.g. "#3B82F6"
  accountId   String?                   // Optional link to Account (INCOME type)
  account     Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  salesItems  SalesItem[]

  @@index([sortOrder])
  @@index([isActive])
}

// ===== Accounting Module =====

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  COGS
  EXPENSE
}

enum AccountTaxCode {
  GST         // Taxable supply / creditable acquisition at 10%
  GST_FREE    // GST-free supply / acquisition
  BAS_EXCLUDED // Outside scope of GST (wages, super, loan repayments)
  INPUT_TAXED  // Input-taxed supply (financial services, residential rent)
}

enum ExpenseStatus {
  DRAFT
  APPROVED
  RECONCILED
}

enum BankTransactionStatus {
  UNMATCHED
  MATCHED
  EXCLUDED
}

enum BankTransactionMatchType {
  INVOICE_PAYMENT
  EXPENSE
  MANUAL
  SPLIT
  BAS_PAYMENT
}

enum BasPeriodStatus {
  DRAFT
  REVIEWED
  LODGED
}

enum VehicleLogbookStatus {
  ACTIVE
  CLOSED
}

enum VehicleTripType {
  BUSINESS
  PRIVATE
}

/// A business vehicle used for the ATO logbook method.
model Vehicle {
  id                  String   @id @default(cuid())
  make                String   @db.VarChar(100)
  model               String   @db.VarChar(100)
  year                Int?
  engineCapacityCc    Int?                             // Engine capacity in cubic centimetres
  registrationNumber  String   @db.VarChar(30)
  colour              String?  @db.VarChar(60)
  notes               String?  @db.Text
  isActive            Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  logbooks        VehicleLogbook[]
  yearlyOdometers VehicleYearlyOdometer[]

  @@index([isActive])
}

/// A logbook period for a vehicle — must cover at least 12 continuous weeks; valid for 5 years.
model VehicleLogbook {
  id            String               @id @default(cuid())
  vehicleId     String
  vehicle       Vehicle              @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  label         String               @db.VarChar(200)   // e.g. "Logbook 2025–26"
  startDate     String                                  // YYYY-MM-DD
  endDate       String?                                 // YYYY-MM-DD — set when closed
  odometerStart Int                                     // km at logbook start
  odometerEnd   Int?                                    // km at logbook close
  status        VehicleLogbookStatus @default(ACTIVE)

  /// Manually overridden business-use percentage once logbook is finalised (0–100).
  /// When null, percentage is computed live from trip records.
  businessUsePercentOverride Float?

  notes         String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trips VehicleTrip[]

  @@index([vehicleId])
  @@index([status])
  @@index([startDate])
}

/// A single trip entry in a vehicle logbook.
model VehicleTrip {
  id          String          @id @default(cuid())
  logbookId   String
  logbook     VehicleLogbook  @relation(fields: [logbookId], references: [id], onDelete: Cascade)

  date            String          // YYYY-MM-DD
  tripType        VehicleTripType
  purpose         String          @db.VarChar(500)   // Business reason or "Private"
  odometerStart   Int?                               // km at trip start (optional — use distanceKm instead)
  odometerEnd     Int?                               // km at trip end
  distanceKm      Float                              // Kilometres travelled — computed from odometer when both are provided
  notes           String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([logbookId])
  @@index([date])
  @@index([tripType])
}

/// Annual odometer readings required by the ATO for each income year a logbook is relied on.
model VehicleYearlyOdometer {
  id            String   @id @default(cuid())
  vehicleId     String
  vehicle       Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  financialYear String   @db.VarChar(20)   // e.g. "FY2026"
  odometerStart Int                        // km at 1 July (or fiscal year start)
  odometerEnd   Int?                       // km at 30 June (or fiscal year end) — set at year close
  notes         String?  @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([vehicleId, financialYear])
  @@index([vehicleId])
}

/// Chart of Accounts — the master list of account codes used across expenses, reports, and BAS.
model Account {
  id          String          @id @default(cuid())
  code        String          @unique @db.VarChar(20)  // e.g. "6-1000"
  name        String          @db.VarChar(200)
  type        AccountType
  subType     String?         @db.VarChar(100)         // e.g. "Motor Vehicle", "Office Supplies"
  taxCode     AccountTaxCode  @default(GST)
  description String?         @db.Text
  isActive    Boolean         @default(true)
  isSystem    Boolean         @default(false)           // System (seed) accounts cannot be deleted

  parentId    String?
  parent      Account?        @relation("AccountChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children    Account[]       @relation("AccountChildren")

  sortOrder   Int             @default(0)

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  expenses         Expense[]
  bankTransactions  BankTransaction[] @relation("BankTransactionAccount")
  journalEntries    JournalEntry[]
  splitLines        SplitLine[]
  salesLabels       SalesLabel[]
  salesSettingsDefault SalesSettings[] @relation("SalesSettingsDefaultIncome")
  basPeriodsGst     BasPeriod[]   @relation("BasPeriodGstAccount")
  basPeriodsPayg    BasPeriod[]   @relation("BasPeriodPaygAccount")
  linkedBankAccount BankAccount?  @relation("BankAccountCoaAccount")

  @@index([type])
  @@index([type, isActive])
  @@index([parentId])
  @@index([sortOrder])
  @@index([code])
}

/// Manual journal entries — for non-bank, non-expense transactions (depreciation, adjustments, etc.)
model JournalEntry {
  id          String   @id @default(cuid())
  date        String                                   // YYYY-MM-DD
  accountId   String
  account     Account  @relation(fields: [accountId], references: [id], onDelete: Restrict)
  description String   @db.Text
  amountCents Int                                      // Positive = debit to account, Negative = credit from account
  taxCode     AccountTaxCode                           // Set by API layer (Zod schema defaults to BAS_EXCLUDED)
  reference   String?  @db.VarChar(500)
  notes       String?  @db.Text
  userId      String?
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  enteredByName String? @db.VarChar(200)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([accountId])
  @@index([date])
}

/// Split lines — when a bank transaction is split across multiple accounts.
model SplitLine {
  id              String   @id @default(cuid())
  bankTransactionId String
  bankTransaction BankTransaction @relation(fields: [bankTransactionId], references: [id], onDelete: Cascade)
  accountId       String
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Restrict)
  description     String   @db.Text
  amountCents     Int                                  // Signed: negative = expense/debit, positive = income/credit
  taxCode         AccountTaxCode @default(GST)

  createdAt       DateTime @default(now())

  @@index([bankTransactionId])
  @@index([accountId])
}

/// Individual file attachment for a bank transaction or expense.
/// Supports multiple files per record, stored in ACCOUNTING_STORAGE_ROOT.
model AccountingAttachment {
  id                  String  @id @default(cuid())
  originalName        String  @db.VarChar(500)

  bankTransactionId   String?
  bankTransaction     BankTransaction? @relation(fields: [bankTransactionId], references: [id], onDelete: Cascade)

  expenseId           String?
  expense             Expense?         @relation(fields: [expenseId], references: [id], onDelete: Cascade)

  basPeriodId         String?
  basPeriod           BasPeriod?       @relation(fields: [basPeriodId], references: [id], onDelete: Cascade)

  uploadedAt          DateTime @default(now())

  @@index([bankTransactionId])
  @@index([expenseId])
  @@index([basPeriodId])
}

/// Business expenses — entered manually or linked to imported bank transactions.
model Expense {
  id           String          @id @default(cuid())

  date         String                                   // YYYY-MM-DD
  supplierName String?         @db.VarChar(300)
  description  String          @db.Text

  accountId    String
  account      Account         @relation(fields: [accountId], references: [id], onDelete: Restrict)

  taxCode      AccountTaxCode  @default(GST)

  // All amounts in cents
  amountExGst  Int
  gstAmount    Int
  amountIncGst Int



  status       ExpenseStatus   @default(DRAFT)

  // Linked bank transaction (set when reconciled against an import)
  bankTransactionId String?     @unique
  bankTransaction   BankTransaction? @relation(fields: [bankTransactionId], references: [id], onDelete: SetNull)

  // Which admin user entered this expense
  userId       String?
  user         User?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  enteredByName String?        @db.VarChar(200)         // Snapshot of name at entry time

  notes        String?         @db.Text

  // Multi-file attachments
  accountingAttachments AccountingAttachment[]

  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt



  @@index([date])
  @@index([accountId])
  @@index([status])
  @@index([userId])
  @@index([bankTransactionId])
}

/// A configured bank account (BSB + account number) used for transaction imports.
model BankAccount {
  id            String   @id @default(cuid())
  name          String   @db.VarChar(200)              // e.g. "Business Cheque Account"
  bankName      String?  @db.VarChar(200)
  bsb           String?  @db.VarChar(10)
  accountNumber String?  @db.VarChar(30)               // last 4 digits shown in UI
  currency      String   @default("AUD") @db.VarChar(5)
  openingBalance     Int  @default(0)                   // cents
  openingBalanceDate String? // YYYY-MM-DD
  isActive      Boolean  @default(true)

  // Optional link to a Chart of Accounts ASSET account so the bank balance
  // appears in the CoA with the correct account code and name.
  coaAccountId  String?  @unique
  coaAccount    Account? @relation("BankAccountCoaAccount", fields: [coaAccountId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  importBatches BankImportBatch[]
  transactions  BankTransaction[]

  @@index([isActive])
}

/// A CSV import batch — one batch per file upload.
model BankImportBatch {
  id            String   @id @default(cuid())
  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  fileName      String   @db.VarChar(500)
  importedAt    DateTime @default(now())
  rowCount      Int      @default(0)
  matchedCount  Int      @default(0)
  skippedCount  Int      @default(0)                    // deduplicated rows skipped

  importedById  String?
  importedByName String? @db.VarChar(200)

  createdAt DateTime @default(now())

  transactions  BankTransaction[]

  @@index([bankAccountId])
  @@index([importedAt])
}

/// An individual bank transaction row imported from CSV.
model BankTransaction {
  id            String   @id @default(cuid())
  bankAccountId String
  bankAccount   BankAccount @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)

  importBatchId String?
  importBatch   BankImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  date          String                                   // YYYY-MM-DD
  description   String   @db.Text
  reference     String?  @db.VarChar(500)
  amountCents   Int                                      // Negative = debit (money out), Positive = credit (money in)
  rawCsv        Json?                                    // Original CSV row as key/value object

  status        BankTransactionStatus    @default(UNMATCHED)
  matchType     BankTransactionMatchType?

  // Link to an invoice payment (matched to invoice)
  invoicePaymentId String? @unique
  invoicePayment   SalesPayment? @relation("BankTransactionPrimaryPayment", fields: [invoicePaymentId], references: [id], onDelete: SetNull)

  // All invoice payments linked to this transaction (primary for single-invoice, all for multi-invoice)
  invoicePayments  SalesPayment[] @relation("SalesPaymentBankTransactionRef")

  // Link to an expense (matched to expense)
  expense       Expense?                                 // Back-relation: Expense.bankTransactionId

  // Link to a BAS period (set when matchType=BAS_PAYMENT)
  basPeriodId   String?  @unique
  basPeriod     BasPeriod? @relation("BankTransactionBasPeriod", fields: [basPeriodId], references: [id], onDelete: SetNull)

  // Set when transaction is posted
  memo                  String?  @db.Text
  transactionType       String?  @db.VarChar(50)        // Expense | Transfer | Deposit | ReceivePayment
  taxCode               AccountTaxCode?
  accountId             String?
  account               Account? @relation("BankTransactionAccount", fields: [accountId], references: [id], onDelete: SetNull)


  // Split lines (when transaction is split across multiple accounts)
  splitLines    SplitLine[]

  // Multi-file attachments (receipts, tax invoices, etc.)
  accountingAttachments AccountingAttachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bankAccountId])
  @@index([date])
  @@index([status])
  @@index([importBatchId])
  @@index([bankAccountId, date])
  @@index([invoicePaymentId])
  @@index([accountId])
}

/// A quarterly BAS period — tracks lodgement status; figures are calculated dynamically.
model BasPeriod {
  id            String          @id @default(cuid())
  label         String          @db.VarChar(100)        // e.g. "Q3 FY2026"
  startDate     String                                   // YYYY-MM-DD
  endDate       String                                   // YYYY-MM-DD
  quarter       Int                                      // 1–4
  financialYear String          @db.VarChar(20)          // e.g. "FY2026"
  status        BasPeriodStatus @default(DRAFT)
  basis         String          @default("CASH")         // CASH or ACCRUAL
  lodgedAt      DateTime?
  notes         String?         @db.Text

  // Overrides for manual BAS label adjustments (e.g. G2 export sales)
  g2Override    Int?                                     // cents
  g3Override    Int?                                     // cents

  // Snapshot of calculation at lodge time (JSON)
  calculationJson Json?
  recordsJson     Json?

  // PAYG amounts — entered alongside BAS figures (cents)
  paygWithholdingCents Int?                            // W2 — amount withheld from wages
  paygInstalmentCents  Int?                            // T7 — PAYG instalment amount

  // Payment recorded after lodging (amounts/accounts stored; bank txn reconciled separately)
  paymentDate              String?                         // YYYY-MM-DD
  paymentAmountCents       Int?                            // Total = gst + payg
  paymentNotes             String?  @db.Text
  paymentGstCents          Int?                            // 1A − 1B net GST component
  paymentGstAccountId      String?                         // FK to Account for GST
  paymentGstAccount        Account? @relation("BasPeriodGstAccount", fields: [paymentGstAccountId], references: [id], onDelete: SetNull)
  paymentPaygCents         Int?                            // T7 PAYG instalment component
  paymentPaygAccountId     String?                         // FK to Account for PAYG
  paymentPaygAccount       Account? @relation("BasPeriodPaygAccount", fields: [paymentPaygAccountId], references: [id], onDelete: SetNull)
  // Back-link to reconciled bank transaction (set when bank txn matched as BAS_PAYMENT)
  bankTransaction          BankTransaction? @relation("BankTransactionBasPeriod")
  accountingAttachments AccountingAttachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([financialYear, quarter])
  @@index([startDate])
  @@index([status])
}

model AccountingSettings {
  id String @id @default("default")

  reportingBasis String @default("CASH")

  // Default Chart of Accounts for BAS payment splitting
  basGstAccountId                String?   // Account for the GST net component (1A − 1B)
  basPaygAccountId               String?   // Account for the PAYG Income Tax Instalment (T7)
  basPaygInstalmentDefaultCents  Int?      // Default T7 amount for new/editable BAS periods

  // Stripe bank-deposit rounding: small differences (≤ $1.00) between the bank deposit and
  // the original Stripe invoice amount are auto-posted to this account as a bank charge.
  stripeRoundingAccountId        String?   // Account for rounding differences (e.g. Bank Charges)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// Tax rate configuration — populates the GST dropdown when posting transactions.
model TaxRate {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(100)              // e.g. "GST (10%)"
  code        String   @db.VarChar(20)               // matches AccountTaxCode: GST | GST_FREE | BAS_EXCLUDED | INPUT_TAXED
  rate        Float    @default(0)                    // 0.10 = 10%
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  notes       String?  @db.Text

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([isActive])
  @@index([sortOrder])
}
