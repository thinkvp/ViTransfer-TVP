model SalesPayment {
  id String @id @default(cuid())

  source SalesPaymentSource @default(MANUAL)

  // If true, this payment is informational/reconciliatory only and should not affect invoice totals/status.
  // Used to prevent double-counting when a Stripe-paid invoice later has an accounting mirror payment imported from QuickBooks.
  excludeFromInvoiceBalance Boolean @default(false)

  paymentDate String
  amountCents Int
  method      String @default("")
  reference   String @default("")

  clientId String?
  client   Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)

  invoiceId String?
  invoice   SalesInvoice? @relation(fields: [invoiceId], references: [id], onDelete: SetNull)

  qboId String? @unique

  // Link back to the bank transaction that settled this payment.
  // Set for all new invoice-match payments; for multi-invoice matches this is the only link
  // (BankTransaction.invoicePaymentId is null).
  bankTransactionId String?
  bankTransactionRef BankTransaction? @relation("SalesPaymentBankTransactionRef", fields: [bankTransactionId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bankTransaction BankTransaction? @relation("BankTransactionPrimaryPayment") // Back-relation: BankTransaction.invoicePaymentId

  @@index([paymentDate])
  @@index([clientId])
  @@index([invoiceId])
  @@index([source])
  @@index([bankTransactionId])
}

model SalesNativeStore {
