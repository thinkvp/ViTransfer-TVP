// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String?  @unique
  password     String
  name         String?
  notes        String?
  phone        String?  // Optional phone number
  avatarPath   String?  // Storage path for profile picture (300x300 JPEG)
  displayColor String?  @db.VarChar(7) // Hex color (#RRGGBB) used for comment/timeline highlights
  active       Boolean  @default(true)
  appRoleId    String
  appRole      Role     @relation(fields: [appRoleId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Secret, tokenized URL for the user's calendar subscription feed (ICS)
  calendarFeedToken String?  @unique

  projects                Project[]
  assignedProjects        ProjectUser[]
  comments                Comment[]
  internalProjectComments ProjectInternalComment[]
  passkeys                PasskeyCredential[]
  projectStatusChanges    ProjectStatusChange[]

  notificationReadState NotificationReadState?

  userKeyDates UserKeyDate[]

  salesQuoteRevisions   SalesQuoteRevision[]
  salesInvoiceRevisions SalesInvoiceRevision[]

  webPushSubscriptions WebPushSubscription[]
  files                UserFile[]

  projectViewSettings UserProjectViewSettings[]

  kanbanCardMemberships KanbanCardMember[]
  kanbanCardsCreated     KanbanCard[] @relation("kanbanCreator")
  kanbanCardComments     KanbanCardComment[]
  kanbanCardHistory      KanbanCardHistory[]

  expenses Expense[]
  journalEntries JournalEntry[]

  @@index([active])
}

model Role {
  id            String   @id @default(cuid())
  name          String   @unique
  isSystemAdmin Boolean  @default(false)
  permissions   Json
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  users User[]
}

model Client {
  id                   String    @id @default(cuid())
  name                 String    @unique
  quickbooksCustomerId String?   @unique
  address              String?
  phone                String?
  website              String?
  notes                String?
  active               Boolean   @default(true)
  deletedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  recipients ClientRecipient[]
  files      ClientFile[]
  projects   Project[]

  salesQuotes   SalesQuote[]
  salesInvoices SalesInvoice[]
  salesPayments SalesPayment[]
  kanbanCards   KanbanCard[]

  @@index([deletedAt])
  @@index([active])
  @@index([name])
  @@index([quickbooksCustomerId])
}

model ClientRecipient {
  id                   String   @id @default(cuid())
  clientId             String
  client               Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  email                String?
  name                 String?
  displayColor         String?  @db.VarChar(7)
  isPrimary            Boolean  @default(false)
  receiveNotifications Boolean  @default(true)
  receiveSalesReminders Boolean @default(true)
  createdAt            DateTime @default(now())

  projectRecipients     ProjectRecipient[]

  @@index([clientId])
  @@index([clientId, email])
}

model SalesReminderSettings {
  id String @id @default("default")

  overdueInvoiceRemindersEnabled     Boolean @default(false)
  overdueInvoiceBusinessDaysAfterDue Int     @default(3)

  quoteExpiryRemindersEnabled             Boolean @default(false)
  quoteExpiryBusinessDaysBeforeValidUntil Int     @default(3)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ClientFile {
  id       String @id @default(cuid())
  clientId String
  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  fileName    String
  fileSize    BigInt
  fileType    String
  storagePath String
  category    String?

  uploadedBy     String?
  uploadedByName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([clientId])
  @@index([clientId, category])
}

model UserFile {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  fileName    String
  fileSize    BigInt
  fileType    String
  storagePath String
  category    String?

  uploadedBy     String?
  uploadedByName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, category])
}



model Project {
  id              String  @id @default(cuid())
  title           String
  slug            String  @unique
  description     String?
  companyName     String? // Optional company/brand name (display priority: companyName → primary recipient → 'Client')
  clientId        String?
  client          Client? @relation(fields: [clientId], references: [id], onDelete: SetNull)
  storagePath     String?
  sharePassword   String?
  authMode        String  @default("PASSWORD") // Authentication mode: PASSWORD, OTP, BOTH, or NONE
  guestMode       Boolean @default(false) // Allow guest access with limited view (videos only, no comments/approval)
  guestLatestOnly Boolean @default(true) // Guests can only view latest version of each video
  allowAuthenticatedProjectSwitching Boolean @default(true) // Allow password/OTP recipients to switch to other current client projects and back

  // Project Type
  enableVideos Boolean @default(true)
  enablePhotos Boolean @default(false)

  // Revision tracking (optional)
  enableRevisions Boolean @default(false)
  maxRevisions    Int     @default(3)

  status          ProjectStatus @default(NOT_STARTED)
  startDate       DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  lastAccessedAt  DateTime?
  approvedAt      DateTime?
  approvedVideoId String? // ID of the video that was approved (null if not approved)

  // Precomputed storage total (bytes) for dashboard display.
  // Updated incrementally when related files are added/removed, and reconciled daily by the worker.
  totalBytes BigInt @default(0)

  // On-disk storage total (bytes) for the project volume folder.
  // This includes derived/transcoded artifacts (previews, thumbnails, timeline sprites/VTT, etc)
  // and any other files present under projects/{projectId}.
  // Nullable so we can distinguish "not computed yet" from a real 0-byte project.
  // Updated via the daily reconcile job and manual admin action.
  diskBytes BigInt?

  // Comment restrictions
  restrictCommentsToLatestVersion Boolean @default(false)
  hideFeedback                    Boolean @default(false)
  useFullTimecode                 Boolean @default(false) // Display comment times as full timecode (HH:MM:SS:FF / DF) instead of M:SS
  allowClientDeleteComments       Boolean @default(false)
  allowClientUploadFiles          Boolean @default(false) // Allow clients to upload files with comments
  maxClientUploadAllocationMB     Int     @default(1000) // Total allowed client comment-attachment uploads per project (0 = unlimited)

  // Video processing settings
  previewResolutions      String  @default("[\"720p\"]") // JSON array of resolutions: ["480p","720p","1080p"]
  watermarkEnabled        Boolean @default(true) // Enable/disable watermarks for this project
  watermarkText           String? // Custom watermark text (null = use default format)
  timelinePreviewsEnabled Boolean @default(false) // Generate timeline preview thumbnails for this project

  // Asset download settings
  allowAssetDownload Boolean @default(true) // Allow clients to download video assets when project is approved

  // Client notification settings (per-project)
  // Note: Approval emails are always IMMEDIATE regardless of this setting
  clientNotificationSchedule String    @default("HOURLY") // IMMEDIATE, HOURLY, DAILY, NONE
  clientNotificationTime     String? // "09:00" for daily
  clientNotificationDay      Int? // unused, kept for migration safety
  lastClientNotificationSent DateTime?

  createdBy   User   @relation(fields: [createdById], references: [id])
  createdById String

  assignedUsers ProjectUser[]

  videos            Video[]
  albums            Album[]
  comments          Comment[]
  internalComments  ProjectInternalComment[]
  securityEvents    SecurityEvent[]
  analytics         VideoAnalytics[]
  albumAnalytics    AlbumAnalytics[]
  recipients        ProjectRecipient[] // Multiple email recipients
  notificationQueue NotificationQueue[] // Pending notifications
  sharePageAccesses SharePageAccess[] // Share page authentication tracking
  guestVideoShareLinks GuestVideoShareLink[] // Per-video-version guest-only share links
  emailEvents       ProjectEmailEvent[] // Logged client email notifications
  emailTracking     EmailTracking[] // Email open tracking pixels
  commentFiles      CommentFile[] // Files uploaded with comments
  files             ProjectFile[] // Internal-only project documents (briefs, references)

  // Imported communications (uploaded .eml emails)
  emails ProjectEmail[]

  // Key Dates (internal schedule milestones)
  keyDates ProjectKeyDate[]

  statusChanges ProjectStatusChange[]

  salesQuotes   SalesQuote[]
  salesInvoices SalesInvoice[]

  viewSettings UserProjectViewSettings[]

  kanbanCards KanbanCard[]
}

enum ProjectKeyDateType {
  PRE_PRODUCTION
  SHOOTING
  DUE_DATE
  OTHER
}

model ProjectKeyDate {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // ISO date and time strings (avoid timezone drift)
  date       String // YYYY-MM-DD
  allDay     Boolean @default(false)
  startTime  String? // HH:MM
  finishTime String? // HH:MM

  type  ProjectKeyDateType
  notes String?

  // Optional reminder (internal email) for this key date
  reminderAt           DateTime?
  reminderTargets      Json?
  reminderSentAt       DateTime?
  reminderLastAttemptAt DateTime?
  reminderAttemptCount Int      @default(0)
  reminderLastError    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([projectId, date])
  @@index([reminderAt])
  @@index([reminderSentAt])
}

model UserKeyDate {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // ISO date and time strings (avoid timezone drift)
  date       String // YYYY-MM-DD
  allDay     Boolean @default(false)
  startTime  String? // HH:MM
  finishTime String? // HH:MM

  title String
  notes String?

  // Optional reminder (internal email) for this personal key date
  reminderAt            DateTime?
  reminderTargets       Json?
  reminderSentAt        DateTime?
  reminderLastAttemptAt DateTime?
  reminderAttemptCount  Int      @default(0)
  reminderLastError     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([userId, date])
  @@index([reminderAt])
  @@index([reminderSentAt])
}

enum ProjectEmailStatus {
  UPLOADING
  PROCESSING
  READY
  ERROR
}

model ProjectEmail {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Original uploaded EML
  rawFileName    String
  rawFileSize    BigInt
  rawFileType    String
  rawStoragePath String
  rawSha256      String? @db.VarChar(64)

  // Parsed metadata
  subject   String?
  fromName  String?
  fromEmail String?
  sentAt    DateTime?

  // Parsed bodies
  textBody String?
  htmlBody String?

  // Attachments summary
  attachmentsCount Int     @default(0)
  hasAttachments   Boolean @default(false)

  status       ProjectEmailStatus @default(UPLOADING)
  errorMessage String?

  uploadedBy     String?
  uploadedByName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  attachments ProjectEmailAttachment[]

  @@unique([projectId, rawSha256])
  @@index([projectId])
  @@index([projectId, sentAt])
  @@index([projectId, createdAt])
}

model ProjectEmailAttachment {
  id             String       @id @default(cuid())
  projectEmailId String
  projectEmail   ProjectEmail @relation(fields: [projectEmailId], references: [id], onDelete: Cascade)

  fileName    String
  fileSize    BigInt
  fileType    String
  storagePath String

  // Inline images support (cid:)
  isInline  Boolean @default(false)
  contentId String?

  createdAt DateTime @default(now())

  @@index([projectEmailId])
}

model Album {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name              String
  storageFolderName String?
  notes String? @db.VarChar(500)

  status AlbumStatus @default(READY)

  // Cached ZIP artifacts (bytes). Updated by the album ZIP worker.
  // These represent storage usage of generated download zips.
  fullZipFileSize   BigInt @default(0)
  socialZipFileSize BigInt @default(0)

  // Whether social-media-sized photo derivatives (long edge scaled to 2048px) are generated for this album.
  socialCopiesEnabled Boolean @default(true)

  // Dropbox upload tracking for generated ZIP files.
  // null = not queued; PENDING = queued; UPLOADING = in progress; COMPLETE = done; ERROR = failed.
  dropboxEnabled           Boolean @default(false)
  fullZipDropboxStatus     String?
  fullZipDropboxProgress   Int     @default(0)
  fullZipDropboxError      String?
  fullZipDropboxPath       String?
  socialZipDropboxStatus   String?
  socialZipDropboxProgress Int     @default(0)
  socialZipDropboxError    String?
  socialZipDropboxPath     String?

  photos AlbumPhoto[]
  analytics AlbumAnalytics[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([projectId, createdAt])
}

enum AlbumStatus {
  UPLOADING
  PROCESSING
  READY
  ERROR
}

model AlbumPhoto {
  id      String @id @default(cuid())
  albumId String
  album   Album  @relation(fields: [albumId], references: [id], onDelete: Cascade)

  fileName    String
  fileSize    BigInt
  fileType    String
  storagePath String
  status      AlbumPhotoStatus @default(UPLOADING)
  error       String?

  socialStoragePath String?
  socialStatus      AlbumPhotoSocialStatus @default(PENDING)
  socialError       String?
  socialGeneratedAt DateTime?
  socialFileSize    BigInt                 @default(0)

  analytics AlbumAnalytics[]

  uploadedBy     String?
  uploadedByName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([albumId])
  @@index([albumId, status])
  @@index([albumId, socialStatus])
}

enum AlbumPhotoStatus {
  UPLOADING
  READY
  ERROR
}

enum AlbumPhotoSocialStatus {
  PENDING
  PROCESSING
  READY
  ERROR
}

model ProjectFile {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  fileName    String
  fileSize    BigInt
  fileType    String
  storagePath String
  category    String?

  uploadedBy     String?
  uploadedByName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([projectId])
  @@index([projectId, category])
}

model ProjectUser {
  projectId            String
  userId               String
  receiveNotifications Boolean  @default(true)
  createdAt            DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([projectId, userId])
  @@index([userId])
}

model ProjectStatusChange {
  id             String                    @id @default(cuid())
  projectId      String
  project        Project                   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  previousStatus ProjectStatus
  currentStatus  ProjectStatus
  source         ProjectStatusChangeSource @default(SYSTEM)
  changedById    String?
  changedBy      User?                     @relation(fields: [changedById], references: [id], onDelete: SetNull)
  createdAt      DateTime                  @default(now())

  @@index([projectId, createdAt])
}

enum ProjectStatusChangeSource {
  ADMIN
  CLIENT
  SYSTEM
}

enum ProjectStatus {
  IN_REVIEW
  ON_HOLD
  APPROVED
  SHARE_ONLY
  NOT_STARTED
  IN_PROGRESS
  REVIEWED
  CLOSED
}

model ProjectRecipient {
  id                   String   @id @default(cuid())
  projectId            String
  project              Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clientRecipientId    String?
  clientRecipient      ClientRecipient? @relation(fields: [clientRecipientId], references: [id], onDelete: SetNull)
  email                String?
  name                 String?
  displayColor         String?  @db.VarChar(7) // Hex color (#RRGGBB) used for comment/timeline highlights
  isPrimary            Boolean  @default(false)
  receiveNotifications Boolean  @default(true) // Per-recipient notification toggle
  createdAt            DateTime @default(now())

  comments Comment[]

  @@index([projectId])
  @@index([clientRecipientId])
  @@index([projectId, email])
}

model Video {
  id           String @id @default(cuid())
  projectId    String
  name         String // Name to distinguish different videos in a project (required)
  storageFolderName String?
  version      Int // 1, 2, 3 (for revisions)
  versionLabel String // "v1", "v2", "v3" or custom

  // Optional notes shown to clients/admins (max 500 chars)
  videoNotes String? @db.VarChar(500)

  // Original file
  originalFileName    String
  originalFileSize    BigInt
  originalStoragePath String

  // Video metadata
  duration Float // in seconds
  width    Int
  height   Int
  fps      Float?
  codec    String?

  // Processing status
  status             VideoStatus @default(UPLOADING)
  uploadProgress     Int         @default(0) // 0-100 percentage
  processingProgress Float       @default(0)
  processingPhase    String?     // Current processing phase: 'transcode' | 'thumbnail' | 'timeline'
  processingError    String?

  // Preview versions (watermarked)
  preview1080Path String?
  preview720Path  String?
  preview480Path  String?
  thumbnailPath   String?

  // Timeline preview thumbnails (sprite sheets)
  timelinePreviewsReady      Boolean @default(false)
  timelinePreviewVttPath     String?
  timelinePreviewSpritesPath String?

  // Per-video approval
  approved   Boolean   @default(false)
  approvedAt DateTime?
  allowApproval Boolean @default(false)

  // Dropbox storage
  dropboxEnabled Boolean @default(false)
  dropboxPath    String? // Human-friendly Dropbox path relative to root (e.g. "Project Name/Video Name/v1 - file.mp4")

  // Dropbox background upload tracking
  dropboxUploadStatus   String? // PENDING, UPLOADING, COMPLETE, ERROR
  dropboxUploadProgress Float   @default(0)
  dropboxUploadError    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project       Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  comments      Comment[]
  analytics     VideoAnalytics[]
  assets        VideoAsset[]
  emailEvents   ProjectEmailEvent[]
  emailTracking EmailTracking[]
  guestVideoShareLinks GuestVideoShareLink[]

  @@index([projectId, version])
  @@index([projectId, name])
  @@index([status])
  @@index([projectId, status])
}

model VideoAsset {
  id      String @id @default(cuid())
  videoId String
  video   Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  // File information
  fileName    String // Original filename (e.g., "project.prproj", "music.mp3", "photo.jpg")
  fileSize    BigInt
  fileType    String // MIME type (e.g., "application/octet-stream", "image/jpeg", "audio/mpeg")
  storagePath String // Path in storage system
  category    String? // Optional category: "image", "audio", "project", "other"

  // Dropbox storage
  dropboxEnabled        Boolean @default(false)
  dropboxPath           String? // Human-friendly Dropbox path relative to root
  dropboxUploadStatus   String? // PENDING, UPLOADING, COMPLETE, ERROR
  dropboxUploadProgress Float   @default(0)
  dropboxUploadError    String?

  // Upload metadata
  expiresAt      DateTime?
  uploadedByName String? // Display name of uploader

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([videoId])
  @@index([videoId, category])
}

enum VideoStatus {
  UPLOADING
  QUEUED
  PROCESSING
  READY
  ERROR
}

model Comment {
  id           String   @id @default(cuid())
  projectId    String
  videoId      String // All comments must be video-specific
  video        Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)
  videoVersion Int? // track which version this comment was for
  timecode     String // HH:MM:SS:FF format (e.g., "00:00:32:15" for 32 seconds 15 frames at given FPS)
  content      String
  authorName   String? // made optional to allow anonymous comments
  authorEmail  String?
  isInternal   Boolean  @default(false) // true = from studio, false = from client
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Snapshot display colour at creation time.
  // Used as a fallback if the linked user/recipient is later deleted (FK will set ids to null).
  displayColorSnapshot String? @db.VarChar(7)

  // Client recipient tracking (for share-page comments)
  recipientId String? // ProjectRecipient who authored this client comment
  recipient   ProjectRecipient? @relation(fields: [recipientId], references: [id], onDelete: SetNull)

  // Admin user tracking (for internal comments)
  userId String? // Admin user who created this comment
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Admin reply functionality
  parentId String? // if this is a reply to another comment
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  files   CommentFile[] // Files uploaded with this comment

  @@index([projectId])
  @@index([videoId])
  @@index([projectId, videoId])
  @@index([parentId])
  @@index([userId])
  @@index([recipientId])
}

model ProjectInternalComment {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // User who authored this internal comment (nullable to preserve history if user is deleted)
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Snapshot display properties at creation time (fallback if user is later deleted/changed)
  authorNameSnapshot   String?
  displayColorSnapshot String? @db.VarChar(7)

  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Reply threading
  parentId String?
  parent   ProjectInternalComment?  @relation("ProjectInternalCommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  ProjectInternalComment[] @relation("ProjectInternalCommentReplies")

  @@index([projectId])
  @@index([projectId, createdAt])
  @@index([parentId])
  @@index([userId])
}

model NotificationQueue {
  id        String  @id @default(cuid())
  projectId String?
  type      NotificationQueueType

  kanbanCardId String?

  // Dual tracking for admin vs client notifications
  sentToClients Boolean   @default(false)
  sentToAdmins  Boolean   @default(false)
  clientSentAt  DateTime?
  adminSentAt   DateTime?

  // Retry and failure tracking
  clientAttempts Int     @default(0) // Number of send attempts to clients
  adminAttempts  Int     @default(0) // Number of send attempts to admins
  clientFailed   Boolean @default(false) // Permanently failed to send to clients
  adminFailed    Boolean @default(false) // Permanently failed to send to admins
  lastError      String? // Last error message for debugging

  data      Json // Stores: commentId, videoId, videoName, authorName, content, timestamp, isReply, etc.
  createdAt DateTime @default(now())

  project    Project?    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  kanbanCard KanbanCard? @relation(fields: [kanbanCardId], references: [id], onDelete: Cascade)

  @@index([projectId, sentToClients])
  @@index([projectId, sentToAdmins])
  @@index([sentToAdmins, createdAt])
  @@index([clientFailed, adminFailed])
  @@index([kanbanCardId])
}

model Settings {
  id String @id @default("default")

  // Company Branding
  companyName     String?         @default("Studio") // Displayed in feedback/comments
  companyLogoMode CompanyLogoMode @default(NONE)
  companyLogoPath String? // Stored logo for email communications (storage path)
  companyLogoUrl  String? // Direct URL to a hosted logo (PNG/JPG)
  darkLogoEnabled Boolean         @default(false) // Whether a separate dark-theme logo is active
  darkLogoMode    CompanyLogoMode @default(NONE)
  darkLogoPath    String? // Stored dark-theme logo (storage path)
  darkLogoUrl     String? // Direct URL to a hosted dark-theme logo (PNG/JPG)
  accentColor     String? // Custom accent hex colour (e.g. "#FF6600") — overrides default blue app-wide
  accentTextMode  String  @default("LIGHT") // LIGHT (white) or DARK (almost-black) text on accent-coloured buttons

  // Theme Preferences
  defaultTheme     String  @default("DARK") // LIGHT, DARK, or AUTO (system decides)
  allowThemeToggle Boolean @default(true) // Whether clients/users can toggle theme

  // Email Header Branding
  emailHeaderColor    String? // Custom email header background hex colour (default #1F1F1F)
  emailHeaderTextMode String  @default("LIGHT") // LIGHT (white) or DARK (almost-black) text in email header

  // Browser Branding
  companyFaviconMode CompanyLogoMode @default(NONE)
  companyFaviconPath String? // Stored favicon (storage path)
  companyFaviconUrl  String? // Direct URL to a hosted favicon (PNG)

  // SMTP Email Configuration
  smtpServer      String?
  smtpPort        Int?    @default(587)
  smtpUsername    String?
  smtpPassword    String?
  smtpFromAddress String?
  smtpSecure      String? @default("STARTTLS") // Options: "STARTTLS", "TLS", "NONE"

  // Email privacy / tracking
  emailTrackingPixelsEnabled Boolean @default(true)
  emailCustomFooterText      String? // Customisable notice displayed at the bottom of client-facing emails

  // Domain Configuration
  appDomain         String? // e.g., "https://yourdomain.com"
  mainCompanyDomain String? // e.g., "https://yourcompany.com" — makes logos clickable links

  // Browser Web Push (admin-only)
  webPushVapidPublicKey          String?
  webPushVapidPrivateKeyEncrypted String?

  // Upload Settings
  maxUploadSizeGB Int @default(1) // Max upload size in GB
  uploadChunkSizeMB Int @default(200) // TUS PATCH chunk size in MB
  downloadChunkSizeMB Int @default(16) // Read/download chunk size in MB

  // Default Video Processing Settings
  defaultPreviewResolutions      String? @default("[\"720p\"]")
  defaultWatermarkEnabled        Boolean @default(true)
  defaultTimelinePreviewsEnabled Boolean @default(false)
  defaultWatermarkText           String?

  // Default project behavior
  defaultAllowClientDeleteComments   Boolean @default(false)
  defaultAllowClientUploadFiles      Boolean @default(false) // Default toggle for client file uploads
  defaultAllowAuthenticatedProjectSwitching Boolean @default(true) // Default toggle for authenticated client project switching
  defaultMaxClientUploadAllocationMB Int     @default(1000) // Default total allowed client comment-attachment uploads per project (0 = unlimited)

  // Project Behavior
  autoApproveProject           Boolean @default(true) // Auto-approve project when all videos approved
  autoDeletePreviewsOnClose    Boolean @default(false) // Auto-delete video previews when a project is closed
  excludeInternalIpsFromAnalytics Boolean @default(true) // Exclude likely internal/admin IPs from public analytics tracking

  // Auto-close approved projects

  // Internal comment notification tracking (uses admin notification schedule)
  lastInternalCommentNotificationSent DateTime?
  // Task comment notification tracking (uses admin notification schedule)
  lastTaskCommentNotificationSent     DateTime?
  autoCloseApprovedProjectsEnabled    Boolean   @default(false)
  autoCloseApprovedProjectsAfterDays  Int       @default(7) // 1-99 days

  // Admin notification settings (global)
  // Note: Approval emails and manual admin notifications are always IMMEDIATE regardless of this setting
  adminNotificationSchedule String    @default("HOURLY") // IMMEDIATE, HOURLY, DAILY, NONE
  adminNotificationTime     String? // "09:00" for daily
  adminNotificationDay      Int? // unused, kept for migration safety
  lastAdminNotificationSent DateTime?

  // Per-type admin email toggles (all enabled by default)
  adminEmailProjectApproved  Boolean @default(true) // Admin notified when client approves all videos
  adminEmailInternalComments Boolean @default(true) // Internal comment summaries on admin schedule
  adminEmailTaskComments     Boolean @default(true) // Task comment summaries on admin schedule
  adminEmailInvoicePaid      Boolean @default(true) // Auto-notify when Stripe payment received
  adminEmailQuoteAccepted    Boolean @default(true) // Auto-notify when client accepts a quote
  adminEmailProjectKeyDates  Boolean @default(true) // Project key date reminders
  adminEmailUserKeyDates     Boolean @default(true) // Personal / user key date reminders

  // Default client notification settings for newly created projects
  defaultClientNotificationSchedule String  @default("HOURLY") // IMMEDIATE, HOURLY, DAILY, NONE
  defaultClientNotificationTime     String? // "09:00" for daily
  defaultClientNotificationDay      Int?    // unused, kept for consistency

  // Per-type client email toggles (global defaults, all enabled by default)
  clientEmailProjectApproved Boolean @default(true) // Client notified when entire project is approved

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

