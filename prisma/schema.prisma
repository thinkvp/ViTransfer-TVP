model VideoAnalytics {
  id String @id @default(cuid())

  videoId String
  video   Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)

  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  // Event types: PAGE_VISIT, DOWNLOAD_COMPLETE (legacy), DOWNLOAD_SUCCEEDED, DOWNLOAD_FAILED
  eventType String

  // Optional: Single asset ID for individual asset downloads
  assetId String?

  // Optional: Multiple asset IDs for ZIP downloads (JSON array)
  assetIds String?

  // Viewer IP (best-effort; may be null for older records)
  ipAddress String?

  // Share session ID for mapping to a recipient (best-effort)
  sessionId String?

  // Authentication metadata captured at the time of the event
  accessMethod String?
  email        String?

  // Additional context for richer analytics entries (speed, failure reason, etc.)
  details Json?

  createdAt DateTime @default(now())

  @@index([projectId, createdAt])
  @@index([videoId, createdAt])
  @@index([eventType])
  @@index([assetId])
  @@index([ipAddress])
  @@index([sessionId])
