{
  "name": "vitransfer",
  "version": "2.2.2",
  "private": true,
  "engines": {
    "node": ">=24",
    "npm": ">=11"
  },
  "scripts": {
    "dev": "next dev",
    "prebuild": "prisma generate && node scripts/ensure-prisma-client.mjs && node scripts/clean-next.mjs",
    "build": "next build --webpack",
    "start": "next start",
    "start:standalone": "node .next/standalone/server.js",
    "check:rbac": "node scripts/check-rbac-gates.mjs",
    "test:smoke": "npm run check:rbac && tsx scripts/smoke-test.ts",
    "test:e2e": "tsx scripts/smoke-e2e.ts",
    "lint": "eslint .",
    "test:share-uploads:api": "tsx scripts/check-share-uploads-api.ts",
    "test:share-uploads:ui": "tsx scripts/check-share-uploads-ui.ts",
    "test:share-uploads": "npm run test:share-uploads:api && npm run test:share-uploads:ui",
    "postinstall": "patch-package && prisma generate && node scripts/ensure-prisma-client.mjs",
    "worker": "tsx src/worker/index.ts",
    "preview:emails": "tsx scripts/render-email-previews.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "@aws-sdk/client-s3": "^3.1045.0",
    "@aws-sdk/lib-storage": "^3.1045.0",
    "@aws-sdk/s3-request-presigner": "^3.1045.0",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@simplewebauthn/browser": "^13.2.2",
    "@simplewebauthn/server": "^13.2.3",
    "@tus/file-store": "^2.0.0",
    "@tus/server": "^2.3.0",
    "archiver": "^8.0.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.76.5",
    "class-variance-authority": "^0.7.1",
    "client-zip": "^2.5.0",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.11",
    "dotenv": "^17.4.2",
    "file-type": "^22.0.1",
    "hls.js": "^1.6.16",
    "html-to-text": "^10.0.0",
    "ioredis": "^5.10.0",
    "isomorphic-dompurify": "^3.1.0",
    "jsonwebtoken": "^9.0.2",
    "lucide-react": "^1.23.0",
    "mailparser": "^3.9.11",
    "mammoth": "^1.12.0",
    "next": "^16.2.3",
    "nodemailer": "^9.0.1",
    "openai": "^6.45.0",
    "pdf-lib": "^1.17.1",
    "pg": "^8.22.0",
    "prisma": "^7.8.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "recharts": "^3.8.1",
    "sharp": "^0.35.3",
    "sonner": "^2.0.7",
    "stripe": "^14.24.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7",
    "tus-js-client": "^4.2.3",
    "unpdf": "^1.6.2",
    "web-push": "^3.6.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.2",
    "@types/archiver": "^8.0.0",
    "@types/html-to-text": "^9.0.4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^24.10.9",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.7",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3"
  },
  "overrides": {
    "mailparser": {
      "nodemailer": "$nodemailer"
    },
    "next": {
      "postcss": ">=8.5.10"
    },
    "uuid": ">=11.1.1",
    "@hono/node-server": ">=1.19.13",
    "fast-xml-parser": "5.7.3",
    "esbuild": "0.28.1",
    "glob": "13.0.6",
    "jsdom": "28.1.0",
    "lodash": "4.18.1",
    "undici": "7.28.0",
