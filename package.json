    "brace-expansion": "5.0.6",
    "bn.js": "4.12.3",
    "effect": ">=3.20.0",
    "flatted": "3.4.2",
    "picomatch": "2.3.2",
    "tinyglobby": {
      "picomatch": "4.0.4"
    },
    "srvx": "0.11.13",
    "yaml": "2.8.3"
  }
}
